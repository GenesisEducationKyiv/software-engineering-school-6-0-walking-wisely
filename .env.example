# REST/gRPC servers
REST_PORT=8080
GRPC_PORT=9090

# PostgreSQL - full DSN
DATABASE_URL=postgres://genesis:genesis@localhost:5432/genesis?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# NATS JetStream event broker
NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=EVENTS
NATS_SUBJECT_PREFIX=events
NATS_CONSUMER_NAME=notifications
NATS_BATCH_SIZE=32
NATS_ACK_WAIT=5s
NATS_MAX_DELIVERIES=5
NATS_DLQ_SUBJECT=events_dlq.notifications

# Resend (https://resend.com)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# HMAC-SHA256 secret for confirm/unsubscribe token generation - keep this secret
EMAIL_SECRET_KEY=change-me-to-a-long-random-string

# Public base URL used to build confirm/unsubscribe links in emails
BASE_URL=https://releases-api.app

# GitHub personal access token (optional - raises rate limit from 60 to 5000 req/h)
GITHUB_TOKEN=

# Structured logging (optional)
LOG_LEVEL=info             # debug, info, warn, error
SERVICE_NAME=github-release-notifier
ENVIRONMENT=local

# Worker tuning (optional - these are the defaults)
SCANNER_INTERVAL=5m        # how often to check repos for new releases
OUTBOX_CLEANUP_INTERVAL=30m # how often to delete delivered outbox rows past retention
OUTBOX_RETENTION=168h      # keep delivered outbox rows for 7 days before cleanup

# Notifications service tuning (optional)
RESEND_MAX_WAIT=200ms      # max time to buffer emails before flushing a batch
NOTIFICATION_JOB_INSERT_BATCH_SIZE=500 # notification job rows inserted per database batch
NOTIFICATION_JOB_CLEANUP_INTERVAL=30m # how often to delete sent notification jobs past retention
NOTIFICATION_JOB_RETENTION=168h # keep sent notification jobs for 7 days before cleanup

# DB connection retry (optional)
DB_RETRY_MAX_ATTEMPTS=5
DB_RETRY_INITIAL_WAIT_MS=500
DB_RETRY_MAX_WAIT_MS=30000

# Redis connection retry (optional)
REDIS_RETRY_MAX_ATTEMPTS=5
REDIS_RETRY_INITIAL_WAIT_MS=500
REDIS_RETRY_MAX_WAIT_MS=30000

# NATS connection retry (optional)
NATS_RETRY_MAX_ATTEMPTS=5
NATS_RETRY_INITIAL_WAIT_MS=500
NATS_RETRY_MAX_WAIT_MS=30000
