# REST/gRPC servers
REST_PORT=8080
GRPC_PORT=9090

# PostgreSQL - full DSN
DATABASE_URL=postgres://genesis:genesis@localhost:5432/genesis?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Resend (https://resend.com)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# HMAC-SHA256 secret for confirm/unsubscribe token generation - keep this secret
EMAIL_SECRET_KEY=change-me-to-a-long-random-string

# Public base URL used to build confirm/unsubscribe links in emails
BASE_URL=https://releases-api.app

# GitHub personal access token (optional - raises rate limit from 60 to 5000 req/h)
GITHUB_TOKEN=

# Structured logging (optional)
LOG_LEVEL=info             # debug, info, warn, error
SERVICE_NAME=github-release-notifier
ENVIRONMENT=local

# Worker tuning (optional - these are the defaults)
SCANNER_INTERVAL=5m        # how often to check repos for new releases

# Redis Streams event bus (optional - these are the defaults)
STREAM_KEY=events          # Redis Stream key shared between API and notifications service
STREAM_GROUP=notifications # Consumer group name used by the notifications service
STREAM_BATCH_SIZE=32       # Redis Stream messages read per notifications consumer batch
STREAM_MAX_LEN=100000      # Redis Stream max length for trimming; 0 disables trimming
STREAM_RECLAIM_AFTER=5m    # Time before idle messages are reclaimed by notifications consumer
STREAM_RECLAIM_TICK=5m     # Interval for checking idle messages to reclaim
STREAM_ACK_TIMEOUT=5s      # Timeout for acknowledging processed messages
STREAM_MAX_DELIVERIES=5    # Max delivery attempts before moving to DLQ
STREAM_DLQ_KEY=events.dlq  # Dead-letter queue key for failed messages
# Notifications service tuning (optional)
RESEND_MAX_WAIT=200ms      # max time to buffer emails before flushing a batch

# DB connection retry (optional)
DB_RETRY_MAX_ATTEMPTS=5
DB_RETRY_INITIAL_WAIT_MS=500
DB_RETRY_MAX_WAIT_MS=30000

# Redis connection retry (optional)
REDIS_RETRY_MAX_ATTEMPTS=5
REDIS_RETRY_INITIAL_WAIT_MS=500
REDIS_RETRY_MAX_WAIT_MS=30000
